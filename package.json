    "configuration": {
      "title": "Kronos",
      "properties": {
        "kronos.pollIntervalSec": {
          "type": "number",
          "default": 300,
          "description": "How often to auto-refresh project status (seconds)"
        },
        "kronos.sessionPollIntervalMs": {
          "type": "number",
          "default": 5000,
          "description": "How often to poll claude agents for session status (ms)"
        },
        "kronos.reviewPollIntervalSec": {
          "type": "number",
          "default": 300,
          "description": "How often to poll review merge requests for status changes (seconds)"
        },
        "kronos.profile": {
          "type": "string",
          "default": "enterprise-gitlab-jira",
          "enum": [
            "enterprise-gitlab-jira",
            "personal-local",
            "github-actions",
            "no-sonar"
          ],
          "description": "Kronos integration profile for provider/default-branch assumptions."
        },
        "kronos.dispatchModel": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Claude model ID for dispatched sessions (e.g. claude-opus-4-6, claude-opus-4-6[1m])"
        },
        "kronos.defaultBaseBranch": {
          "type": "string",
          "default": "develop",
          "description": "Default base branch for Kronos worktrees when project config does not set base_branch or default_branch."
        },
        "kronos.trendWindowDays": {
          "type": "number",
          "default": 14,
          "description": "Lookback window in days for Kronos trend metrics."
        },
        "kronos.staleReviewDays": {
          "type": "number",
          "default": 3,
          "description": "Days before an open MR waiting for review is reported as stale."
        },
        "kronos.staleBuildFailureDays": {
          "type": "number",
          "default": 1,
          "description": "Days before a failing build or fix_build ticket is reported as stale."
        },
        "kronos.staleBlockedDays": {
          "type": "number",
          "default": 2,
          "description": "Days before a blocked ticket is reported as stale."
        },
        "kronos.staleVerificationDays": {
          "type": "number",
          "default": 5,
          "description": "Days before a verify or deploy-monitor ticket is reported as stale."
        },
        "kronos.staleTicketDays": {
          "type": "number",
          "default": 14,
          "description": "Days before an implement or in-progress ticket is reported as stale."
        }
      }
