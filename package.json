{
  "name": "kronos",
  "displayName": "Kronos — Terminal Work Companion",
  "description": "Terminal-first Jira, merge-request, pipeline, and audit context for interactive sessions. Kronos reads, inserts, monitors, audits, and launches Claude only from an explicit operator action.",
  "version": "0.1.0",
  "publisher": "jmacke01",
  "author": {
    "name": "Jeremy Mackey",
    "url": "https://github.com/jmac4909"
  },
  "license": "SEE LICENSE IN LICENSE",
  "preview": true,
  "homepage": "https://github.com/jmac4909/Kronos#readme",
  "bugs": {
    "url": "https://github.com/jmac4909/Kronos/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmac4909/kronos.git"
  },
  "keywords": [
    "vscode-extension",
    "typescript",
    "terminal",
    "jira",
    "gitlab",
    "jenkins",
    "sonarqube",
    "pipeline",
    "audit",
    "claude-code",
    "ai-assisted-development",
    "developer-tools",
    "human-in-the-loop"
  ],
  "icon": "media/kronos-marketplace-icon.png",
  "galleryBanner": {
    "color": "#0b1220",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Kronos reads provider context, writes private local context and audit records, and can insert non-submitting references into an operator-owned terminal. Claude launch is disabled in untrusted workspaces. Kronos never executes workspace code, runs project commands, or changes Git."
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kronos",
          "title": "Kronos",
          "icon": "media/kronos-icon.svg"
        }
      ]
    },
    "views": {
      "kronos": [
        {
          "id": "kronosWork",
          "name": "Work"
        },
        {
          "id": "kronosSessions",
          "name": "Sessions"
        },
        {
          "id": "kronosProjects",
          "name": "Projects"
        },
        {
          "id": "kronosAttention",
          "name": "Attention"
        }
      ]
    },
    "commands": [
      {
        "command": "kronos.refreshTickets",
        "title": "Kronos: Refresh Jira Tickets",
        "icon": "$(refresh)"
      },
      {
        "command": "kronos.openJiraBoard",
        "title": "Kronos: Open Jira Work Board",
        "icon": "$(layout)"
      },
      {
        "command": "kronos.filterWork",
        "title": "Kronos: Filter Work",
        "icon": "$(filter)"
      },
      {
        "command": "kronos.clearWorkFilter",
        "title": "Kronos: Clear Work Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "kronos.openTicketWorkspace",
        "title": "Kronos: Open Ticket Workspace",
        "icon": "$(open-preview)"
      },
      {
        "command": "kronos.configureProjectDiscoveryFolders",
        "title": "Kronos: Choose Project Discovery Folders",
        "icon": "$(folder-opened)"
      },
      {
        "command": "kronos.registerWorkspaceProject",
        "title": "Kronos: Manage Registered Projects",
        "icon": "$(folder-library)"
      },
      {
        "command": "kronos.chooseTicketProject",
        "title": "Kronos: Choose Ticket Project and Branch",
        "icon": "$(repo)"
      },
      {
        "command": "kronos.newClaudeSession",
        "title": "Kronos: New Claude Session",
        "icon": "$(add)"
      },
      {
        "command": "kronos.startClaudeForTicket",
        "title": "Kronos: Start Claude for Ticket",
        "icon": "$(terminal)"
      },
      {
        "command": "kronos.manageActiveTerminal",
        "title": "Kronos: Manage Focused Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "kronos.insertJiraContext",
        "title": "Kronos: Insert Jira Context",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "kronos.insertOtherTicket",
        "title": "Kronos: Insert Other Ticket into Session",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "kronos.insertGitLabContext",
        "title": "Kronos: Insert Merge Request and Pipeline Context",
        "icon": "$(git-merge)"
      },
      {
        "command": "kronos.insertCiContext",
        "title": "Kronos: Insert Jenkins and SonarQube Context",
        "icon": "$(beaker)"
      },
      {
        "command": "kronos.openContextBasket",
        "title": "Kronos: Open Context Basket",
        "icon": "$(archive)"
      },
      {
        "command": "kronos.searchLocalEvidence",
        "title": "Kronos: Search Local Sessions and Evidence",
        "icon": "$(search)"
      },
      {
        "command": "kronos.createLocalHandoff",
        "title": "Kronos: Create Private Local Handoff",
        "icon": "$(export)"
      },
      {
        "command": "kronos.pollManagedWorkSessions",
        "title": "Kronos: Poll Managed Providers",
        "icon": "$(sync)"
      },
      {
        "command": "kronos.openWorkSessionAudit",
        "title": "Kronos: Open Work Session Audit",
        "icon": "$(history)"
      },
      {
        "command": "kronos.focusWorkSessionTerminal",
        "title": "Kronos: Open Session Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "kronos.reattachWorkSessionTerminal",
        "title": "Kronos: Reconnect Focused Terminal to Session",
        "icon": "$(link)"
      },
      {
        "command": "kronos.detachWorkSessionTerminal",
        "title": "Kronos: Detach Terminal",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "kronos.closeWorkSession",
        "title": "Kronos: Stop Managing Work Session",
        "icon": "$(close)"
      },
      {
        "command": "kronos.removeWorkSession",
        "title": "Kronos: Remove Session from Kronos",
        "icon": "$(trash)"
      },
      {
        "command": "kronos.refreshProjects",
        "title": "Kronos: Refresh Project Branches and Status",
        "icon": "$(refresh)"
      },
      {
        "command": "kronos.renameLocalProject",
        "title": "Kronos: Set Project Nickname",
        "icon": "$(edit)"
      },
      {
        "command": "kronos.openProjectGitStatus",
        "title": "Kronos: View Project Git Status and Diff",
        "icon": "$(open-preview)"
      },
      {
        "command": "kronos.insertProjectGitContext",
        "title": "Kronos: Insert Project Working Diff Context",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "kronos.openProjectMergeRequest",
        "title": "Kronos: Open Project Merge Request Page",
        "icon": "$(git-merge)"
      },
      {
        "command": "kronos.insertProjectGitLabContext",
        "title": "Kronos: Insert Project Merge Request Evidence",
        "icon": "$(git-merge)"
      },
      {
        "command": "kronos.insertProjectCiContext",
        "title": "Kronos: Insert Project Jenkins and SonarQube Evidence",
        "icon": "$(beaker)"
      },
      {
        "command": "kronos.configureProjectIntegrations",
        "title": "Kronos: Configure Project Provider Polling",
        "icon": "$(settings-gear)"
      },
      {
        "command": "kronos.pauseWorkSessionMonitoring",
        "title": "Kronos: Pause Work Session Monitoring",
        "icon": "$(debug-pause)"
      },
      {
        "command": "kronos.resumeWorkSessionMonitoring",
        "title": "Kronos: Resume Work Session Monitoring",
        "icon": "$(debug-start)"
      },
      {
        "command": "kronos.acknowledgeAttention",
        "title": "Kronos: Clear Attention Item (Audit Retained)",
        "icon": "$(check)"
      },
      {
        "command": "kronos.openProvider",
        "title": "Kronos: Open Provider Page",
        "icon": "$(link-external)"
      },
      {
        "command": "kronos.setup",
        "title": "Kronos: Setup",
        "icon": "$(tools)"
      },
      {
        "command": "kronos.doctor",
        "title": "Kronos: Doctor",
        "icon": "$(pulse)"
      },
      {
        "command": "kronos.settings",
        "title": "Kronos: Guided Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kronos.refreshTickets",
          "when": "view == kronosWork",
          "group": "navigation@1"
        },
        {
          "command": "kronos.openJiraBoard",
          "when": "view == kronosWork",
          "group": "navigation@2"
        },
        {
          "command": "kronos.filterWork",
          "when": "view == kronosWork",
          "group": "navigation@3"
        },
        {
          "command": "kronos.clearWorkFilter",
          "when": "view == kronosWork",
          "group": "work@1"
        },
        {
          "command": "kronos.newClaudeSession",
          "when": "view == kronosSessions",
          "group": "navigation@1"
        },
        {
          "command": "kronos.manageActiveTerminal",
          "when": "view == kronosSessions",
          "group": "navigation@2"
        },
        {
          "command": "kronos.refreshProjects",
          "when": "view == kronosProjects",
          "group": "navigation@1"
        },
        {
          "command": "kronos.registerWorkspaceProject",
          "when": "view == kronosProjects",
          "group": "navigation@2"
        },
        {
          "command": "kronos.pollManagedWorkSessions",
          "when": "view == kronosAttention",
          "group": "navigation@1"
        },
        {
          "command": "kronos.pollManagedWorkSessions",
          "when": "view == kronosSessions",
          "group": "sessions@1"
        },
        {
          "command": "kronos.pollManagedWorkSessions",
          "when": "view == kronosProjects",
          "group": "projects@1"
        },
        {
          "command": "kronos.openContextBasket",
          "when": "view == kronosWork",
          "group": "work@2"
        },
        {
          "command": "kronos.openContextBasket",
          "when": "view == kronosSessions",
          "group": "sessions@2"
        },
        {
          "command": "kronos.openContextBasket",
          "when": "view == kronosProjects",
          "group": "projects@2"
        },
        {
          "command": "kronos.searchLocalEvidence",
          "when": "view == kronosWork",
          "group": "work@3"
        },
        {
          "command": "kronos.searchLocalEvidence",
          "when": "view == kronosSessions",
          "group": "sessions@3"
        },
        {
          "command": "kronos.searchLocalEvidence",
          "when": "view == kronosProjects",
          "group": "projects@3"
        },
        {
          "command": "kronos.searchLocalEvidence",
          "when": "view == kronosAttention",
          "group": "attention@1"
        },
        {
          "command": "kronos.createLocalHandoff",
          "when": "view == kronosSessions",
          "group": "sessions@4"
        },
        {
          "command": "kronos.createLocalHandoff",
          "when": "view == kronosProjects",
          "group": "projects@4"
        },
        {
          "command": "kronos.setup",
          "when": "view == kronosWork",
          "group": "work@4"
        }
      ],
      "view/item/context": [
        {
          "command": "kronos.openTicketWorkspace",
          "when": "viewItem == work_ticket",
          "group": "inline@1"
        },
        {
          "command": "kronos.startClaudeForTicket",
          "when": "viewItem == work_ticket",
          "group": "inline@2"
        },
        {
          "command": "kronos.manageActiveTerminal",
          "when": "viewItem == work_ticket",
          "group": "terminal@1"
        },
        {
          "command": "kronos.chooseTicketProject",
          "when": "viewItem == work_ticket",
          "group": "project@1"
        },
        {
          "command": "kronos.insertJiraContext",
          "when": "viewItem == work_ticket",
          "group": "context@1"
        },
        {
          "command": "kronos.insertGitLabContext",
          "when": "viewItem == work_ticket",
          "group": "context@2"
        },
        {
          "command": "kronos.insertCiContext",
          "when": "viewItem == work_ticket",
          "group": "context@3"
        },
        {
          "command": "kronos.focusWorkSessionTerminal",
          "when": "viewItem == work_session_attached || viewItem == work_session_attached_paused || viewItem == standalone_session_attached",
          "group": "inline@1"
        },
        {
          "command": "kronos.reattachWorkSessionTerminal",
          "when": "viewItem == work_session_detached || viewItem == work_session_detached_paused || viewItem == work_session_closed || viewItem == standalone_session_detached || viewItem == standalone_session_closed",
          "group": "inline@1"
        },
        {
          "command": "kronos.openWorkSessionAudit",
          "when": "viewItem == work_session_attached || viewItem == work_session_detached || viewItem == work_session_attached_paused || viewItem == work_session_detached_paused || viewItem == work_session_closed || viewItem == standalone_session_attached || viewItem == standalone_session_detached || viewItem == standalone_session_closed",
          "group": "audit@1"
        },
        {
          "command": "kronos.insertOtherTicket",
          "when": "viewItem == work_session_attached || viewItem == work_session_attached_paused || viewItem == standalone_session_attached",
          "group": "context@1"
        },
        {
          "command": "kronos.pauseWorkSessionMonitoring",
          "when": "viewItem == work_session_attached || viewItem == work_session_detached",
          "group": "monitoring@1"
        },
        {
          "command": "kronos.resumeWorkSessionMonitoring",
          "when": "viewItem == work_session_attached_paused || viewItem == work_session_detached_paused",
          "group": "monitoring@1"
        },
        {
          "command": "kronos.detachWorkSessionTerminal",
          "when": "viewItem == work_session_attached || viewItem == work_session_attached_paused || viewItem == standalone_session_attached",
          "group": "management@1"
        },
        {
          "command": "kronos.closeWorkSession",
          "when": "viewItem == work_session_attached || viewItem == work_session_detached || viewItem == work_session_attached_paused || viewItem == work_session_detached_paused || viewItem == standalone_session_attached || viewItem == standalone_session_detached",
          "group": "management@2"
        },
        {
          "command": "kronos.removeWorkSession",
          "when": "viewItem == work_session_attached || viewItem == work_session_detached || viewItem == work_session_attached_paused || viewItem == work_session_detached_paused || viewItem == work_session_closed || viewItem == standalone_session_attached || viewItem == standalone_session_detached || viewItem == standalone_session_closed",
          "group": "management@3"
        },
        {
          "command": "kronos.newClaudeSession",
          "when": "viewItem == registered_project",
          "group": "inline@1"
        },
        {
          "command": "kronos.insertProjectGitContext",
          "when": "viewItem == registered_project",
          "group": "inline@2"
        },
        {
          "command": "kronos.openProjectMergeRequest",
          "when": "viewItem == registered_project",
          "group": "project@1"
        },
        {
          "command": "kronos.insertProjectGitLabContext",
          "when": "viewItem == registered_project",
          "group": "context@1"
        },
        {
          "command": "kronos.insertProjectCiContext",
          "when": "viewItem == registered_project",
          "group": "context@2"
        },
        {
          "command": "kronos.configureProjectIntegrations",
          "when": "viewItem == registered_project",
          "group": "management@1"
        },
        {
          "command": "kronos.renameLocalProject",
          "when": "viewItem == registered_project",
          "group": "management@2"
        },
        {
          "command": "kronos.acknowledgeAttention",
          "when": "viewItem =~ /^attention_(provider|repair)/",
          "group": "inline@1"
        },
        {
          "command": "kronos.openProvider",
          "when": "viewItem =~ /^attention_provider/",
          "group": "inline@2"
        },
        {
          "command": "kronos.openTicketWorkspace",
          "when": "viewItem =~ /^attention_(provider|repair)_ticket/",
          "group": "ticket@1"
        },
        {
          "command": "kronos.insertGitLabContext",
          "when": "viewItem =~ /^attention_(provider|repair)_ticket_gitlab$/",
          "group": "context@1"
        },
        {
          "command": "kronos.insertCiContext",
          "when": "viewItem =~ /^attention_(provider|repair)_ticket_ci$/",
          "group": "context@2"
        },
        {
          "command": "kronos.openWorkSessionAudit",
          "when": "viewItem =~ /^attention_(provider|repair)/",
          "group": "audit@1"
        }
      ]
    },
    "configuration": {
      "title": "Kronos — Terminal Work Companion",
      "properties": {
        "kronos.refreshIntervalSec": {
          "type": "number",
          "default": 300,
          "minimum": 15,
          "description": "How often Kronos refreshes Jira work metadata, in seconds."
        },
        "kronos.managedProviderPollIntervalSec": {
          "type": "number",
          "default": 300,
          "minimum": 15,
          "description": "How often Kronos reads GitLab, Jenkins, and SonarQube status for monitored work sessions, in seconds."
        },
        "kronos.projectDiscoveryRoots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "machine",
          "description": "Parent folders Kronos may inspect for local Git projects when Manage Registered Projects is explicitly opened. Choose folders from Kronos Setup or use this advanced setting. Open workspace folders are always offered. Use ~ for the current home folder."
        },
        "kronos.projectDiscoveryDepth": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "scope": "machine",
          "description": "Maximum child-directory depth inspected below each configured project discovery root. Discovery is bounded and read-only."
        },
        "kronos.projectDiscoveryLimit": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "maximum": 500,
          "scope": "machine",
          "description": "Maximum number of local project candidates shown by one explicit discovery action."
        },
        "kronos.hideCompletedJiraWork": {
          "type": "boolean",
          "default": true,
          "description": "Hide completed Jira tickets by default in both the Work tree and Jira board. Explicit filters and saved board choices still take precedence."
        },
        "kronos.completedJiraStatuses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional Jira status names that Kronos should treat as completed, for teams whose workflow does not use Jira's Done status category."
        },
        "kronos.claudeCommand": {
          "type": "string",
          "default": "claude",
          "scope": "machine",
          "description": "Validated Claude CLI command submitted only after New Claude Session or Start Claude for Ticket. Only claude/claude-* plus approved interactive model, effort, safe-mode, IDE, and display flags are accepted. Permission behavior is controlled by the separate Claude Permission Mode setting."
        },
        "kronos.claudePermissionMode": {
          "type": "string",
          "enum": [
            "default",
            "acceptEdits",
            "plan",
            "auto",
            "dontAsk",
            "bypassPermissions"
          ],
          "enumDescriptions": [
            "Manual/default: Claude asks before edits and commands that require approval.",
            "Accept Edits: Claude may edit files and perform supported in-scope filesystem operations without prompting; other commands still prompt.",
            "Plan: Claude starts in analysis and planning mode before edits are approved.",
            "Auto: a supported Claude CLI and account use Claude's safety classifier to reduce routine prompts. Availability depends on the installed CLI, model, and account.",
            "Don't Ask: only tools already approved by Claude permission rules run; otherwise Claude receives a denial instead of prompting.",
            "Experimental Bypass Permissions: Claude skips normal permission prompts. Kronos shows a blocking modal warning on every launch. Use only in an isolated environment you control."
          ],
          "default": "default",
          "scope": "machine",
          "description": "Starting permission mode for explicit Kronos Claude launches. Raw permission flags in Claude Command are rejected so this typed setting remains the single permission-policy control."
        },
        "kronos.claudeTerminalName": {
          "type": "string",
          "default": "Claude",
          "description": "Base name for terminals created by an explicit Kronos Claude launch."
        },
        "kronos.claudeLaunchCwd": {
          "type": "string",
          "enum": [
            "ticketProject",
            "workspace",
            "home"
          ],
          "enumDescriptions": [
            "Use the ticket's configured project folder, then fall back to the workspace or home folder.",
            "Use the first open workspace folder, then fall back to the home folder.",
            "Use the current user's home folder."
          ],
          "default": "ticketProject",
          "description": "Starting directory for terminals created by an explicit Claude launch."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node scripts/clean-output.js && node node_modules/typescript/bin/tsc -p ./",
    "watch": "node scripts/clean-output.js && node node_modules/typescript/bin/tsc -watch -p ./",
    "package": "npm run release:preflight && npx --yes @vscode/vsce@3.9.2 package --no-dependencies --allow-missing-repository --githubBranch main",
    "release:preflight": "npm run public:check && node scripts/check-manifest.js && node scripts/check-runtime-graph.js && node scripts/check-security.js && node scripts/check-context-governance.js && node scripts/check-roadmap-evidence.js && node scripts/check-quality-evidence.js && npm run compile && npm run release:surface",
    "release:surface": "node scripts/run-release-surface-tests.js",
    "publish:verify": "node scripts/verify-published-branch.js",
    "test": "npm run public:check && node scripts/check-manifest.js && node scripts/check-runtime-graph.js && node scripts/check-security.js && node scripts/check-context-governance.js && node scripts/check-roadmap-evidence.js && node scripts/check-quality-evidence.js && npm run compile && npm run command:routing && npm run product:surface && npm run terminal:lifecycle && npm run persistence:recovery && npm run schema:invariants && npm run failure:contract && npm run provider:readiness && npm run project:catalog && npm run provider:bindings && node scripts/run-unit-tests.js && npm run work:orchestration && npm run provider:reconciliation && npm run attention:matrix && npm run provider:health && npm run provider:fixtures && npm run context:basket && npm run local:search && npm run handoff:profiles && npm run scale:a11y && npm run release:surface && npm run webview:dom && npm run webview:jira-board",
    "public:check": "node scripts/check-public-surface.js",
    "webview:dom": "node scripts/run-webview-dom-tests.js",
    "webview:jira-board": "node scripts/run-jira-work-board-tests.js",
    "provider:fixtures": "node scripts/run-provider-contract-tests.js",
    "scale:a11y": "node scripts/run-scale-accessibility-tests.js",
    "provider:readiness": "node scripts/run-provider-readiness-tests.js",
    "project:catalog": "node scripts/run-project-catalog-tests.js",
    "provider:bindings": "node scripts/run-provider-binding-reconciliation-tests.js",
    "terminal:lifecycle": "node scripts/run-terminal-lifecycle-tests.js",
    "command:routing": "node scripts/run-command-routing-tests.js",
    "product:surface": "node scripts/run-product-surface-contract-tests.js",
    "persistence:recovery": "node scripts/run-persistence-recovery-tests.js",
    "schema:invariants": "node scripts/run-schema-invariant-tests.js",
    "failure:contract": "node scripts/run-failure-contract-tests.js",
    "work:orchestration": "node scripts/run-work-orchestration-tests.js",
    "provider:reconciliation": "node scripts/run-provider-reconciliation-tests.js",
    "attention:matrix": "node scripts/run-attention-transition-matrix-tests.js",
    "provider:health": "node scripts/run-provider-health-visibility-tests.js",
    "context:basket": "node scripts/run-context-basket-tests.js",
    "local:search": "node scripts/run-local-evidence-search-tests.js",
    "handoff:profiles": "node scripts/run-handoff-branch-profile-tests.js",
    "feedback:state": "node scripts/create-feedback-state.js",
    "feedback:state:force": "node scripts/create-feedback-state.js --force",
