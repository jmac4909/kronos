{
  "name": "kronos",
  "displayName": "Kronos — Claude Code Orchestrator",
  "description": "Multi-project orchestration dashboard for Claude Code. Track projects, tickets, MRs, builds, and overnight automation from VS Code.",
  "version": "0.1.0",
  "publisher": "jmacke01",
  "license": "UNLICENSED",
  "keywords": [
    "claude",
    "orchestration",
    "jira",
    "gitlab",
    "automation"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Read-only Kronos dashboards and review panels are available in Restricted Mode. Dispatching agents, modifying repositories, publishing evidence, and destructive cleanup require workspace trust."
    }
  },
