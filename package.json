{
  "name": "kronos",
  "displayName": "Kronos — Terminal Work Companion",
  "description": "Terminal-first Jira, merge-request, pipeline, and audit context for operator-owned interactive sessions. Kronos reads, inserts, monitors, and audits without running your work.",
  "version": "0.1.0",
  "publisher": "jmacke01",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmac4909/kronos.git"
  },
  "keywords": [
    "terminal",
    "jira",
    "gitlab",
    "jenkins",
    "sonarqube",
    "pipeline",
    "audit"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Kronos reads provider context, writes private local context and audit records, and can insert non-submitting references into an operator-owned terminal. It never launches Claude, executes workspace code, runs project commands, or changes Git."
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kronos",
          "title": "Kronos",
          "icon": "media/kronos-icon.svg"
        }
      ]
    },
    "views": {
      "kronos": [
        {
          "id": "kronosWork",
          "name": "Work"
        },
        {
          "id": "kronosSessions",
          "name": "Sessions"
        },
        {
          "id": "kronosAttention",
          "name": "Attention"
        }
      ]
    },
    "commands": [
      {
        "command": "kronos.refreshTickets",
        "title": "Kronos: Refresh Jira Tickets",
        "icon": "$(refresh)"
      },
      {
        "command": "kronos.filterWork",
        "title": "Kronos: Filter Work",
        "icon": "$(filter)"
      },
      {
        "command": "kronos.clearWorkFilter",
        "title": "Kronos: Clear Work Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "kronos.openTicketWorkspace",
        "title": "Kronos: Open Ticket Workspace",
        "icon": "$(open-preview)"
      },
      {
        "command": "kronos.manageActiveTerminal",
        "title": "Kronos: Manage Focused Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "kronos.insertJiraContext",
        "title": "Kronos: Insert Jira Context",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "kronos.insertGitLabContext",
        "title": "Kronos: Insert Merge Request and Pipeline Context",
        "icon": "$(git-merge)"
      },
      {
        "command": "kronos.insertCiContext",
        "title": "Kronos: Insert Jenkins and SonarQube Context",
        "icon": "$(beaker)"
      },
      {
        "command": "kronos.pollManagedWorkSessions",
        "title": "Kronos: Poll Managed Providers",
        "icon": "$(sync)"
      },
      {
        "command": "kronos.openWorkSessionAudit",
        "title": "Kronos: Open Work Session Audit",
        "icon": "$(history)"
      },
      {
        "command": "kronos.focusWorkSessionTerminal",
        "title": "Kronos: Focus Managed Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "kronos.reattachWorkSessionTerminal",
        "title": "Kronos: Reattach Focused Terminal",
        "icon": "$(link)"
      },
      {
        "command": "kronos.detachWorkSessionTerminal",
        "title": "Kronos: Detach Terminal",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "kronos.closeWorkSession",
        "title": "Kronos: Stop Managing Work Session",
        "icon": "$(close)"
      },
      {
        "command": "kronos.pauseWorkSessionMonitoring",
        "title": "Kronos: Pause Work Session Monitoring",
        "icon": "$(debug-pause)"
      },
      {
        "command": "kronos.resumeWorkSessionMonitoring",
        "title": "Kronos: Resume Work Session Monitoring",
        "icon": "$(debug-start)"
      },
      {
        "command": "kronos.acknowledgeAttention",
        "title": "Kronos: Acknowledge Attention Item",
        "icon": "$(check)"
      },
      {
        "command": "kronos.openProvider",
        "title": "Kronos: Open Provider Page",
        "icon": "$(link-external)"
      },
      {
        "command": "kronos.doctor",
        "title": "Kronos: Doctor",
        "icon": "$(pulse)"
      },
      {
        "command": "kronos.settings",
        "title": "Kronos: Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kronos.refreshTickets",
          "when": "view == kronosWork",
          "group": "navigation@1"
        },
        {
          "command": "kronos.filterWork",
          "when": "view == kronosWork",
          "group": "navigation@2"
        },
        {
          "command": "kronos.clearWorkFilter",
          "when": "view == kronosWork",
          "group": "navigation@3"
        },
        {
          "command": "kronos.manageActiveTerminal",
          "when": "view == kronosSessions",
          "group": "navigation@1"
        },
        {
          "command": "kronos.pollManagedWorkSessions",
          "when": "view == kronosSessions || view == kronosAttention",
          "group": "navigation@2"
        },
        {
          "command": "kronos.doctor",
          "when": "view == kronosAttention",
          "group": "navigation@8"
        },
        {
          "command": "kronos.settings",
          "when": "view == kronosAttention",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "kronos.openTicketWorkspace",
          "when": "viewItem == work_ticket",
          "group": "inline@1"
        },
        {
          "command": "kronos.manageActiveTerminal",
          "when": "viewItem == work_ticket",
          "group": "terminal@1"
        },
        {
          "command": "kronos.insertJiraContext",
          "when": "viewItem == work_ticket",
          "group": "context@1"
        },
        {
          "command": "kronos.insertGitLabContext",
          "when": "viewItem == work_ticket",
          "group": "context@2"
        },
        {
          "command": "kronos.insertCiContext",
          "when": "viewItem == work_ticket",
          "group": "context@3"
        },
        {
          "command": "kronos.focusWorkSessionTerminal",
          "when": "viewItem == work_session_attached || viewItem == work_session_attached_paused",
          "group": "inline@1"
        },
        {
          "command": "kronos.reattachWorkSessionTerminal",
          "when": "viewItem == work_session_detached || viewItem == work_session_detached_paused || viewItem == work_session_closed",
          "group": "inline@1"
        },
        {
          "command": "kronos.openWorkSessionAudit",
          "when": "viewItem == work_session_attached || viewItem == work_session_detached || viewItem == work_session_attached_paused || viewItem == work_session_detached_paused || viewItem == work_session_closed",
          "group": "audit@1"
        },
        {
          "command": "kronos.pauseWorkSessionMonitoring",
          "when": "viewItem == work_session_attached || viewItem == work_session_detached",
          "group": "monitoring@1"
        },
        {
          "command": "kronos.resumeWorkSessionMonitoring",
          "when": "viewItem == work_session_attached_paused || viewItem == work_session_detached_paused",
          "group": "monitoring@1"
        },
        {
          "command": "kronos.detachWorkSessionTerminal",
          "when": "viewItem == work_session_attached || viewItem == work_session_attached_paused",
          "group": "management@1"
        },
        {
          "command": "kronos.closeWorkSession",
          "when": "viewItem == work_session_attached || viewItem == work_session_detached || viewItem == work_session_attached_paused || viewItem == work_session_detached_paused",
          "group": "management@2"
        },
        {
          "command": "kronos.acknowledgeAttention",
          "when": "viewItem == attention_item",
          "group": "inline@1"
        },
        {
          "command": "kronos.openProvider",
          "when": "viewItem == attention_item",
          "group": "inline@2"
        },
        {
          "command": "kronos.openTicketWorkspace",
          "when": "viewItem == attention_item",
          "group": "ticket@1"
        },
        {
          "command": "kronos.insertGitLabContext",
          "when": "viewItem == attention_item",
          "group": "context@1"
        },
        {
          "command": "kronos.insertCiContext",
          "when": "viewItem == attention_item",
          "group": "context@2"
        }
      ]
    },
    "configuration": {
      "title": "Kronos — Terminal Work Companion",
      "properties": {
        "kronos.refreshIntervalSec": {
          "type": "number",
          "default": 300,
          "minimum": 15,
          "description": "How often Kronos refreshes Jira work metadata, in seconds."
        },
        "kronos.managedProviderPollIntervalSec": {
          "type": "number",
          "default": 300,
          "minimum": 15,
          "description": "How often Kronos reads GitLab, Jenkins, and SonarQube status for monitored work sessions, in seconds."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node scripts/clean-output.js && node node_modules/typescript/bin/tsc -p ./",
    "watch": "node scripts/clean-output.js && node node_modules/typescript/bin/tsc -watch -p ./",
    "package": "npx --yes @vscode/vsce@3.9.2 package --no-dependencies --allow-missing-repository",
    "test": "node scripts/check-manifest.js && node scripts/check-security.js && node scripts/check-context-governance.js && npm run compile && node scripts/run-unit-tests.js && npm run webview:dom",
    "webview:dom": "node scripts/run-webview-dom-tests.js",
    "feedback:state": "node scripts/create-feedback-state.js",
    "feedback:state:force": "node scripts/create-feedback-state.js --force",
    "feedback:smoke": "node scripts/run-feedback-smoke.js",
    "feedback:ready": "node scripts/prepare-human-feedback.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
