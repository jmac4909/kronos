{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Kronos Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    },
    {
      "name": "Run Kronos Extension (Feedback State)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "env": {
        "KRONOS_DIR": "${workspaceFolder}/.kronos/feedback-state"
      },
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "Kronos: Prepare Feedback Dev Host"
    }
  ]
}
